APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DAILY_DAYS=14
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Paydunya Mobile Money Configuration
# Get your keys at: https://paydunya.com/dashboard
PAYDUNYA_MASTER_KEY=
PAYDUNYA_PRIVATE_KEY=
PAYDUNYA_TOKEN=
PAYDUNYA_MODE=test

# Frontend URL for Paydunya redirects
APP_FRONTEND_URL=http://localhost:3000

# CORS — séparer par virgule, ex: https://cotafoot.com,https://www.cotafoot.com
CORS_ALLOWED_ORIGINS=http://localhost:3000

# API-FOOTBALL API Configuration
# Get your key at: https://developer.sportradar.com
API-FOOTBALL_API_KEY=407380ffde22c517a928cc45db648f56
API-FOOTBALL_BASE_URL=v3.football.api-sports.io

# OpenWeatherMap API (for weather criterion in prediction algorithm)
# Get your key at: https://openweathermap.org/api
OPENWEATHERMAP_KEY=

# Multi-API Stack — 100% Free tier
# football-data.org — matchs backup illimité
FOOTBALL_DATA_ORG_KEY=

# The Odds API — 500 req/mois gratuit
THE_ODDS_API_KEY=

# GNews — 100 req/jour gratuit
GNEWS_API_KEY=

# TheSportsDB — gratuit public (key = "3")
THESPORTSDB_KEY=3

# Firebase Cloud Messaging (FCM v1 — HTTP API v1)
# Obtenir depuis Firebase Console → Project settings → Service accounts → Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_PATH=/path/to/firebase-service-account.json

# Telegram Bot
# Obtenir via @BotFather sur Telegram → /newbot
# AffiliateControl API (Betwinner partenaire)
AFFILIATECONTROL_ACCESS_KEY=
AFFILIATECONTROL_SECRET_KEY=
AFFILIATECONTROL_CUSTOMER_ID=

# Betwinner Affiliation (AffiliateControl)
BETWINNER_AFFILIATE_KEY=

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=COTABot
