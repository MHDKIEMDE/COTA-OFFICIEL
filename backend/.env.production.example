# COTA Backend - Configuration Production
# Copier ce fichier vers .env et remplir toutes les valeurs

# ========================================
# APPLICATION
# ========================================
APP_NAME="COTA"
APP_ENV=production
APP_KEY=base64:GENERER_AVEC_php_artisan_key:generate
APP_DEBUG=false
APP_URL=https://api.cota.app

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ========================================
# LOGGING
# ========================================
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ========================================
# DATABASE (MySQL Production)
# ========================================
DB_CONNECTION=sqlite
DB_DATABASE=/var/www/html/database/database.sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=cota_production
# DB_USERNAME=cota_user
# DB_PASSWORD=GENERER_MOT_DE_PASSE_SECURISE

# ========================================
# SESSION & COOKIES
# ========================================
SESSION_DRIVER=rediaude
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.cota.app
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=strict

# ========================================
# BROADCAST & FILESYSTEM
# ========================================
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3

# ========================================
# QUEUE (Redis Production)
# ========================================
QUEUE_CONNECTION=redis
QUEUE_FAILED_DRIVER=database

# ========================================
# CACHE (Redis Production)
# ========================================
CACHE_STORE=redis
CACHE_PREFIX=cota_

# ========================================
# REDIS (OBLIGATOIRE EN PRODUCTION)
# ========================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2

# ========================================
# MAIL (Production - SMTP Réel)
# ========================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=noreply@cota.app
MAIL_PASSWORD=GENERER_MOT_DE_PASSE_MAIL
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@cota.app
MAIL_FROM_NAME="${APP_NAME}"

# ========================================
# AWS S3 (Stockage fichiers production)
# ========================================
AWS_ACCESS_KEY_ID=VOTRE_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=VOTRE_AWS_SECRET_KEY
AWS_DEFAULT_REGION=eu-west-1
AWS_BUCKET=cota-production-assets
AWS_USE_PATH_STYLE_ENDPOINT=false


# ========================================
# API-FOOTBALL (Backup - optionnel)
# ========================================
FOOTBALL_API_KEY=243eb2c283a1758c9659b000bf2379d1
FOOTBALL_API_BASE_URL=https://v3.football.api-sports.io
FOOTBALL_API_PLAN=premium
FOOTBALL_API_TIMEZONE=Africa/Ouagadougou

# ========================================
# OPENWEATHERMAP (Météo)
# ========================================
OPENWEATHERMAP_KEY=VOTRE_CLE_OPENWEATHERMAP

# ========================================
# PAYDUNYA (PAIEMENTS MOBILE MONEY)
# ========================================
PAYDUNYA_MODE=live
PAYDUNYA_MASTER_KEY=VOTRE_MASTER_KEY_PRODUCTION
PAYDUNYA_PRIVATE_KEY=VOTRE_PRIVATE_KEY_PRODUCTION
PAYDUNYA_TOKEN=VOTRE_TOKEN_PRODUCTION
PAYDUNYA_STORE_NAME="COTA Pronostics"
PAYDUNYA_STORE_URL=https://www.cota.app
PAYDUNYA_WEBHOOK_URL=https://api.cota.app/api/webhooks/paydunya
PAYDUNYA_RETURN_URL=https://www.cota.app/payment/success
PAYDUNYA_CANCEL_URL=https://www.cota.app/payment/cancel

# ========================================
# FACEBOOK OAUTH
# ========================================
FACEBOOK_APP_ID=VOTRE_FACEBOOK_APP_ID_PRODUCTION
FACEBOOK_APP_SECRET=VOTRE_FACEBOOK_APP_SECRET_PRODUCTION
FACEBOOK_REDIRECT_URI=https://api.cota.app/api/auth/facebook/callback

# ========================================
# MONITORING & ERRORS (Sentry)
# ========================================
SENTRY_LARAVEL_DSN=https://VOTRE_SENTRY_DSN@sentry.io/XXXXXX
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ENVIRONMENT=production

# ========================================
# SECURITY
# ========================================
# HTTPS forcé
ASSET_URL=https://api.cota.app

# HSTS (HTTP Strict Transport Security)
HSTS_ENABLED=true
HSTS_MAX_AGE=31536000

# CSP (Content Security Policy)
CSP_ENABLED=true

# Rate Limiting Production (strict)
RATE_LIMIT_AUTH=10  # 10 req/min pour auth (OTP)
RATE_LIMIT_API=30   # 30 req/min pour API authentifiée
RATE_LIMIT_PUBLIC=20  # 20 req/min pour routes publiques

# Sanctum
SANCTUM_STATEFUL_DOMAINS=cota.app,www.cota.app,api.cota.app
SESSION_DOMAIN=.cota.app

# ========================================
# PERFORMANCE
# ========================================
# OPcache (recommandé)
OPCACHE_ENABLED=true

# Compression
COMPRESSION_ENABLED=true

# CDN
CDN_URL=https://cdn.cota.app

# ========================================
# JOBS & SCHEDULER
# ========================================
QUEUE_RETRY_AFTER=90
QUEUE_MAX_TRIES=3

# Supervisor
SUPERVISOR_WORKERS=4

# ========================================
# BACKUP (Automatique)
# ========================================
BACKUP_ENABLED=true
BACKUP_DISK=s3
BACKUP_NOTIFICATION_EMAIL=admin@cota.app

# ========================================
# LEGAL
# ========================================
CGU_URL=https://www.cota.app/legal/cgu
PRIVACY_URL=https://www.cota.app/legal/privacy
MENTIONS_URL=https://www.cota.app/legal/mentions

# ========================================
# NOTES IMPORTANTES
# ========================================
# 1. JAMAIS committer ce fichier avec vraies valeurs
# 2. Générer APP_KEY avec: php artisan key:generate
# 3. Utiliser Redis obligatoirement (cache + queue)
# 4. Configurer Supervisor pour queue:work
# 5. Configurer cron pour schedule:run
# 6. Activer HTTPS avec certificat SSL
# 7. Configurer Sentry pour monitoring erreurs
# 8. Faire backup BDD quotidien
# 9. Tester paiements Paydunya en mode test d'abord
# 10. Vérifier tous les webhooks (Paydunya, Facebook)
